<UserControl x:Class="NoNiDev.ArchipelagoParser.Views.SpoilerView.SpoilerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:NoNiDev.ArchipelagoParser.Views.SpoilerView"
             xmlns:sviewer="clr-namespace:NoNiDev.ArchipelagoParser.Views.CustomUserControl.SpoilerViewer"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid>
        <TreeView ItemsSource="{Binding Games}">
            <TreeView.ItemTemplate>
                <DataTemplate>
                    <TreeViewItem Header="{Binding GamePlusName}" IsExpanded="False">
                        <sviewer:SpoilerGameItem HorizontalContentAlignment="Stretch" />
                    </TreeViewItem>
                </DataTemplate>
            </TreeView.ItemTemplate>
        </TreeView>
    </Grid>
</UserControl>
