<Window x:Class="NoNiDev.ArchipelagoParser.Views.CustomWindows.EditArchipelWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:NoNiDev.ArchipelagoParser.Views.CustomWindows"
        mc:Ignorable="d"
        Title="EditArchipelWindow" Height="450" Width="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="35"/>

        </Grid.RowDefinitions>
        <Grid Grid.Row="0" Margin="73,35,-73,0" Grid.RowSpan="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="150"/>
                <ColumnDefinition Width="20"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="35"/>
                <RowDefinition Height="35"/>
                <RowDefinition Height="35"/>
            </Grid.RowDefinitions>
            <!-- row 0 -->
            <Label Grid.Column="0" Grid.Row="0"
               Content="Name"
               Margin="5,0,15,0" VerticalContentAlignment="Center" HorizontalContentAlignment="Right"/>
            <Label Grid.Column="1" Grid.Row="0"
            Content=":"
            VerticalContentAlignment="Center" HorizontalContentAlignment="Center"/>
            <TextBox Grid.Column="2" Grid.Row="0"
            Text="{Binding Name}"
            HorizontalAlignment="Left" Margin="15,0,5,0" TextWrapping="Wrap" VerticalAlignment="Center" Width="250"/>
            <!-- row 1 -->
            <Label Grid.Column="0" Grid.Row="1"
        Content="URL"
        Margin="5,0,15,0" VerticalContentAlignment="Center" HorizontalContentAlignment="Right"/>
            <Label Grid.Column="1" Grid.Row="1"
            Content=":"
            VerticalContentAlignment="Center" HorizontalContentAlignment="Center"/>
            <TextBox Grid.Column="2" Grid.Row="1" 
                     Text="{Binding Url}" 
                     HorizontalAlignment="Left" Margin="15,0,5,0" TextWrapping="Wrap"  VerticalAlignment="Center" Width="250"/>
            <!-- row 2 -->
            <Label Grid.Column="0" Grid.Row="2"
        Content="État"
        Margin="5,0,15,0" VerticalContentAlignment="Center" HorizontalContentAlignment="Right"/>
            <Label Grid.Column="1" Grid.Row="2"
 Content=":"
 VerticalContentAlignment="Center" HorizontalContentAlignment="Center"/>
            <ComboBox Grid.Column="2" Grid.Row="2" 
                 ItemsSource="{Binding StateList}" SelectedValue="{Binding State}"
     HorizontalAlignment="Left" Margin="15,0,5,0" VerticalAlignment="Center" Width="250"/>
        </Grid>
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Button Grid.Column="0" Content="Cancel" HorizontalAlignment="Right" Command="Close" Width="50" Margin="5"/>
            <Button Grid.Column="1" Content="Save" HorizontalAlignment="Left" Width="50" Margin="5"/>
        </Grid>
    </Grid>
</Window>
