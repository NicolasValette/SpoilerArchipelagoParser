<UserControl x:Class="NoNiDev.ArchipelagoParser.Views.CustomUserControl.ArchipelagoEditor.ArchipelagoEditorLine"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:NoNiDev.ArchipelagoParser.Views.CustomUserControl.ArchipelagoEditor"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>
        <TextBox Grid.Column="0" Text="{Binding ArchipelId}" Margin="5"/>
        <TextBox Grid.Column="1" Text="{Binding ArchipelName}" Margin="5"/>
        <TextBox Grid.Column="2" Text="{Binding NumberOfPlayers}" Margin="5"/>
        <TextBox Grid.Column="3" Text="{Binding NumberOfGames}" Margin="5"/>
        <TextBox Grid.Column="4" Text="{Binding State}" Margin="5"/>
        <TextBox Grid.Column="5" Text="{Binding NumberOfChecks}" Margin="5"/>
        <Button Grid.Column="6" 
            Command="{Binding ButtonEditArchipelRC}"
            Content="Edit" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="5"/>
    </Grid>
</UserControl>
